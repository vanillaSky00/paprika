# ==========================================================================
# Paprika backend - environment template
# Copy to `.env` and fill in your own values. Never commit real secrets.
# ==========================================================================

# --- LLM provider selection -------------------------------------------------
# Which client `get_llm()` returns by default. Options: openai | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini

# --- OpenAI (required for default path + embeddings) ------------------------
# Embeddings use text-embedding-3-small (1536-dim); must match Vector(1536).
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4.1-mini

# --- Ollama (optional alt provider) -----------------------------------------
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:4b

# --- LangSmith tracing (optional) -------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=paprika-agent

# --- OpenWeather tool (optional; tool disables itself if unset) -------------
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# --- Database ---------------------------------------------------------------
# In docker compose this is overridden to point at the `db` service; locally
# leave the default or change host/port to match your Postgres instance.
DATABASE_URL=postgresql+asyncpg://admin:password@localhost:5432/paprika_ai

# Postgres service credentials (read by docker-compose.yml for the `db` container).
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=paprika_ai

# --- Redis ------------------------------------------------------------------
# Overridden to redis://redis:6379/0 inside docker-compose.
REDIS_URL=redis://localhost:6379/0

# --- Logging (nested: mapped to settings.log.*) -----------------------------
# Uses env_nested_delimiter="__" in Settings.
DEBUG=false
LOG__LEVEL=INFO
# Leave empty for console-only logging. Set to a path to also write a rotating file.
LOG__FILE_PATH=
LOG__MAX_BYTES=10485760
LOG__BACKUP_COUNT=5

# --- Grafana / Alloy observability (optional) -------------------------------
# Used by config.alloy (not by Settings). Only needed if you enable the alloy service.
POSTGRES_DSN=postgres://admin:password@db:5432/paprika_ai?sslmode=disable
GRAFANA_PROM_URL=
GRAFANA_PROM_USER=
GRAFANA_PROM_PASS=
